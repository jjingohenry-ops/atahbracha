# Server Configuration
PORT=3000
NODE_ENV=production

# Database Configuration (AWS Aurora PostgreSQL)
DATABASE_URL=postgresql://smartliveadmin:YOUR_PASSWORD@smartlivestock-db.cluster-c0f4iu4a2hub.us-east-1.rds.amazonaws.com:5432/smartlivestock_prod?sslmode=require

# JWT Configuration
JWT_SECRET=smartlivestock-jwt-secret-2024-very-secure-key-change-in-production
JWT_EXPIRES_IN=7d

# File Upload Configuration
UPLOAD_DIR=./src/public/uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,video/mp4,video/webm

# Sync Configuration
SYNC_INTERVAL=30000
MAX_RETRY_ATTEMPTS=3

# External Services (Optional)
WHATSAPP_API_KEY=your-whatsapp-api-key
IP_CAMERA_URLS=http://camera1.local/stream,http://camera2.local/stream

# Firebase Admin SDK Configuration
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40your-project-id.iam.gserviceaccount.com

# CORS Configuration
CORS_ORIGIN=http://localhost:8080
