{
  "name": "smart-livestock-backend",
  "version": "1.0.0",
  "description": "Backend API for Smart Livestock Manager",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon server.ts",
    "build": "tsc",
    "test": "npm run build && node scripts/smoke.test.js",
    "seed:dashboard": "node scripts/seedDashboardData.js",
    "seed:dashboard:local": "node -r dotenv/config scripts/seedDashboardData.js dotenv_config_path=.env.local",
    "seed:insurance": "node scripts/seedInsuranceProviders.js",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build"
  },
  "keywords": [
    "livestock",
    "farming",
    "management",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1009.0",
    "@aws-sdk/client-s3": "^3.1013.0",
    "@prisma/client": "^5.22.0",
    "@prisma/config": "^7.4.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dexie": "^4.3.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/morgan": "^1.9.10",
    "nodemon": "^3.1.14"
  }
}
